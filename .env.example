PORT=3000
JWT_SECRET=o_batismo_portugues_segredo_super_seguro_2026

# Base de Dados (Cloudflare D1 / Local SQLite)
# Se as variáveis Cloudflare D1 forem preenchidas, o Render liga-se diretamente à Cloudflare D1 em Produção!
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_API_TOKEN=

# Ficheiro de reserva local (utilizado se as variáveis da Cloudflare D1 estiverem vazias)
DB_FILE=database.sqlite

# Google Gemini API (Para tradução automática de tarefas PT -> EN)
GEMINI_API_KEY=

# Cloudflare R2 (Opcional - se vazio, utiliza armazenamento local em public/uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
